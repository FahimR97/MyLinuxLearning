[
  {"id":"lab-fp-1","chapterId":"file-permissions","title":"Reading File Permissions","description":"Learn to read and interpret ls -l output.","steps":[{"instruction":"Create a test file","command":"touch ~/testfile.txt","expectedOutput":""},{"instruction":"View its permissions","command":"ls -l ~/testfile.txt","expectedOutput":"-rw-r--r--"},{"instruction":"Check who owns it","command":"stat ~/testfile.txt","expectedOutput":"Uid and Gid fields show your user"}]},
  {"id":"lab-fp-2","chapterId":"file-permissions","title":"Changing Permissions with Octal Mode","description":"Practice setting permissions using numbers.","steps":[{"instruction":"Make the file executable by owner","command":"chmod 755 ~/testfile.txt","expectedOutput":""},{"instruction":"Verify the change","command":"ls -l ~/testfile.txt","expectedOutput":"-rwxr-xr-x"},{"instruction":"Make it private (owner only)","command":"chmod 700 ~/testfile.txt","expectedOutput":""},{"instruction":"Verify","command":"ls -l ~/testfile.txt","expectedOutput":"-rwx------"}]},
  {"id":"lab-fp-3","chapterId":"file-permissions","title":"Symbolic Permission Changes","description":"Use letter-based chmod to modify permissions.","steps":[{"instruction":"Reset permissions","command":"chmod 644 ~/testfile.txt","expectedOutput":""},{"instruction":"Add execute for owner","command":"chmod u+x ~/testfile.txt","expectedOutput":""},{"instruction":"Remove read for others","command":"chmod o-r ~/testfile.txt","expectedOutput":""},{"instruction":"Verify final permissions","command":"ls -l ~/testfile.txt","expectedOutput":"-rwxr--r--  minus the other read"}]},
  {"id":"lab-fp-4","chapterId":"file-permissions","title":"Understanding umask","description":"See how umask affects new file permissions.","steps":[{"instruction":"Check current umask","command":"umask","expectedOutput":"0022 (or similar)"},{"instruction":"Create a file and check permissions","command":"touch ~/umask_test.txt && ls -l ~/umask_test.txt","expectedOutput":"-rw-r--r-- (666 - 022 = 644)"},{"instruction":"Create a directory and check","command":"mkdir ~/umask_test_dir && ls -ld ~/umask_test_dir","expectedOutput":"drwxr-xr-x (777 - 022 = 755)"},{"instruction":"Clean up","command":"rm ~/umask_test.txt ~/testfile.txt && rmdir ~/umask_test_dir","expectedOutput":""}]},
  {"id":"lab-pm-1","chapterId":"process-management","title":"Viewing Processes","description":"Learn to list and inspect running processes.","steps":[{"instruction":"List all processes","command":"ps aux | head -20","expectedOutput":"USER PID %CPU %MEM ... columns"},{"instruction":"Find your shell process","command":"ps aux | grep bash","expectedOutput":"Your bash process listed"},{"instruction":"View the process tree","command":"pstree | head -20","expectedOutput":"Tree structure starting from systemd or init"},{"instruction":"Check your shell's PID","command":"echo $$","expectedOutput":"A number (your shell's PID)"}]},
  {"id":"lab-pm-2","chapterId":"process-management","title":"Sending Signals","description":"Practice sending signals to processes.","steps":[{"instruction":"Start a background process","command":"sleep 300 &","expectedOutput":"[1] PID_NUMBER"},{"instruction":"List background jobs","command":"jobs","expectedOutput":"[1]+  Running  sleep 300 &"},{"instruction":"Send SIGTERM to stop it","command":"kill %1","expectedOutput":"[1]+  Terminated  sleep 300"},{"instruction":"Verify it's gone","command":"jobs","expectedOutput":"No output (no jobs)"}]},
  {"id":"lab-pm-3","chapterId":"process-management","title":"Job Control","description":"Move processes between foreground and background.","steps":[{"instruction":"Start a long-running command","command":"sleep 200","expectedOutput":"(appears to hang — that's normal)"},{"instruction":"Pause it with Ctrl+Z","command":"Press Ctrl+Z","expectedOutput":"[1]+  Stopped  sleep 200"},{"instruction":"Resume in background","command":"bg %1","expectedOutput":"[1]+ sleep 200 &"},{"instruction":"Bring back to foreground and kill","command":"fg %1 then press Ctrl+C","expectedOutput":"Process terminated"}]},
  {"id":"lab-pm-4","chapterId":"process-management","title":"Exploring /proc","description":"Read process information from the /proc filesystem.","steps":[{"instruction":"View CPU info","command":"cat /proc/cpuinfo | head -10","expectedOutput":"processor, model name, cpu MHz"},{"instruction":"View memory info","command":"cat /proc/meminfo | head -5","expectedOutput":"MemTotal, MemFree, MemAvailable"},{"instruction":"Check your shell's status","command":"cat /proc/$$/status | head -10","expectedOutput":"Name: bash, State, Pid fields"}]},
  {"id":"lab-tp-1","chapterId":"text-processing","title":"grep Basics","description":"Search for patterns in text files.","steps":[{"instruction":"Search for your user in passwd","command":"grep $USER /etc/passwd","expectedOutput":"Your user's passwd entry"},{"instruction":"Count lines in passwd","command":"wc -l /etc/passwd","expectedOutput":"Number of lines"},{"instruction":"Find lines with /bin/bash","command":"grep '/bin/bash' /etc/passwd","expectedOutput":"Users with bash shell"},{"instruction":"Case-insensitive search","command":"grep -i 'root' /etc/passwd","expectedOutput":"root user entry"}]},
  {"id":"lab-tp-2","chapterId":"text-processing","title":"Pipes and Redirects","description":"Chain commands together and redirect output.","steps":[{"instruction":"Count users with bash shell","command":"grep '/bin/bash' /etc/passwd | wc -l","expectedOutput":"A number"},{"instruction":"Save output to a file","command":"ps aux > ~/processes.txt","expectedOutput":""},{"instruction":"Append more data","command":"echo '--- END ---' >> ~/processes.txt","expectedOutput":""},{"instruction":"View the last few lines","command":"tail -3 ~/processes.txt","expectedOutput":"Last processes and --- END ---"},{"instruction":"Clean up","command":"rm ~/processes.txt","expectedOutput":""}]},
  {"id":"lab-tp-3","chapterId":"text-processing","title":"awk Column Extraction","description":"Extract and process specific columns from text.","steps":[{"instruction":"Extract usernames from passwd","command":"awk -F: '{print $1}' /etc/passwd | head -10","expectedOutput":"List of usernames"},{"instruction":"Show username and shell","command":"awk -F: '{print $1, $7}' /etc/passwd | head -10","expectedOutput":"username shell pairs"},{"instruction":"Extract PIDs from ps","command":"ps aux | awk '{print $2}' | head -10","expectedOutput":"List of PIDs"}]},
  {"id":"lab-tp-4","chapterId":"text-processing","title":"The Counting Pipeline","description":"Use sort | uniq -c | sort -rn to count occurrences.","steps":[{"instruction":"Count shells used by users","command":"awk -F: '{print $7}' /etc/passwd | sort | uniq -c | sort -rn","expectedOutput":"Counts of each shell, most common first"},{"instruction":"Count words in a command's output","command":"echo 'the cat sat on the mat the cat' | tr ' ' '\\n' | sort | uniq -c | sort -rn","expectedOutput":"3 the, 2 cat, 1 sat, 1 on, 1 mat"}]},
  {"id":"lab-tp-5","chapterId":"text-processing","title":"sed Find and Replace","description":"Transform text with sed.","steps":[{"instruction":"Create a test file","command":"echo -e 'Hello World\\nHello Linux\\nGoodbye World' > ~/sed_test.txt","expectedOutput":""},{"instruction":"Replace World with Earth","command":"sed 's/World/Earth/' ~/sed_test.txt","expectedOutput":"Hello Earth, Hello Linux, Goodbye Earth"},{"instruction":"Delete lines with Goodbye","command":"sed '/Goodbye/d' ~/sed_test.txt","expectedOutput":"Hello World, Hello Linux"},{"instruction":"Clean up","command":"rm ~/sed_test.txt","expectedOutput":""}]},
  {"id":"lab-um-1","chapterId":"user-management","title":"Exploring User Files","description":"Read the key user management files.","steps":[{"instruction":"View your entry in passwd","command":"grep $USER /etc/passwd","expectedOutput":"Your username:x:UID:GID:..."},{"instruction":"Check your UID and groups","command":"id","expectedOutput":"uid=XXXX(you) gid=XXXX groups=..."},{"instruction":"List all groups","command":"cat /etc/group | head -20","expectedOutput":"Group entries"}]},
  {"id":"lab-um-2","chapterId":"user-management","title":"Understanding /etc/passwd Fields","description":"Parse and understand each field in /etc/passwd.","steps":[{"instruction":"Show just usernames and shells","command":"awk -F: '{print $1, $7}' /etc/passwd","expectedOutput":"username shell pairs"},{"instruction":"Find system accounts (UID < 1000)","command":"awk -F: '$3 < 1000 {print $1, $3}' /etc/passwd","expectedOutput":"System accounts with low UIDs"},{"instruction":"Count total users","command":"wc -l /etc/passwd","expectedOutput":"Number of user entries"}]},
  {"id":"lab-um-3","chapterId":"user-management","title":"Group Management","description":"Work with groups on the system.","steps":[{"instruction":"List your groups","command":"groups","expectedOutput":"Your group memberships"},{"instruction":"View group file","command":"cat /etc/group | grep $USER","expectedOutput":"Groups containing your user"},{"instruction":"Check group details with id","command":"id $USER","expectedOutput":"Full uid, gid, groups output"}]},
  {"id":"lab-um-4","chapterId":"user-management","title":"sudo vs su","description":"Understand the difference between sudo and su.","steps":[{"instruction":"Run a command as root with sudo","command":"sudo whoami","expectedOutput":"root"},{"instruction":"Check sudo log (if accessible)","command":"sudo grep 'sudo' /var/log/auth.log 2>/dev/null || sudo journalctl _COMM=sudo | tail -5","expectedOutput":"Recent sudo usage entries"},{"instruction":"Check who can use sudo","command":"sudo cat /etc/sudoers | grep -v '^#' | grep -v '^$' | head -10","expectedOutput":"Sudoers rules"}]},
  {"id":"lab-fs-1","chapterId":"filesystem","title":"Exploring the Hierarchy","description":"Navigate and understand the Linux directory structure.","steps":[{"instruction":"List top-level directories","command":"ls /","expectedOutput":"bin boot dev etc home lib ..."},{"instruction":"Check what's in /etc","command":"ls /etc | head -20","expectedOutput":"Configuration files and directories"},{"instruction":"Look at /proc","command":"ls /proc | head -20","expectedOutput":"Numbers (PIDs) and system files"},{"instruction":"Check /dev","command":"ls /dev | head -20","expectedOutput":"Device files"}]},
  {"id":"lab-fs-2","chapterId":"filesystem","title":"Inodes and Links","description":"Understand inodes and create hard and symbolic links.","steps":[{"instruction":"Create a test file","command":"echo 'Hello' > ~/link_test.txt","expectedOutput":""},{"instruction":"View its inode","command":"ls -i ~/link_test.txt","expectedOutput":"INODE_NUMBER link_test.txt"},{"instruction":"Create a hard link","command":"ln ~/link_test.txt ~/hardlink.txt","expectedOutput":""},{"instruction":"Verify same inode","command":"ls -li ~/link_test.txt ~/hardlink.txt","expectedOutput":"Both show the same inode number"},{"instruction":"Create a symbolic link","command":"ln -s ~/link_test.txt ~/symlink.txt","expectedOutput":""},{"instruction":"Compare inodes","command":"ls -li ~/link_test.txt ~/symlink.txt","expectedOutput":"Different inode numbers, symlink shows ->"}]},
  {"id":"lab-fs-3","chapterId":"filesystem","title":"Link Behavior When Deleting","description":"See what happens when you delete the original file.","steps":[{"instruction":"Delete the original file","command":"rm ~/link_test.txt","expectedOutput":""},{"instruction":"Hard link still works","command":"cat ~/hardlink.txt","expectedOutput":"Hello"},{"instruction":"Symlink is broken","command":"cat ~/symlink.txt","expectedOutput":"No such file or directory"},{"instruction":"Clean up","command":"rm ~/hardlink.txt ~/symlink.txt","expectedOutput":""}]},
  {"id":"lab-fs-4","chapterId":"filesystem","title":"Disk Usage","description":"Check disk space and directory sizes.","steps":[{"instruction":"Check disk space","command":"df -h","expectedOutput":"Filesystem Size Used Avail Use% Mounted"},{"instruction":"Check inode usage","command":"df -i | head -5","expectedOutput":"Inode usage per filesystem"},{"instruction":"Size of /var","command":"sudo du -sh /var 2>/dev/null","expectedOutput":"Size of /var directory"},{"instruction":"Find large directories","command":"sudo du -sh /* 2>/dev/null | sort -rh | head -10","expectedOutput":"Largest directories first"}]},
  {"id":"lab-sd-1","chapterId":"systemd-services","title":"Viewing Service Status","description":"Check the status of system services.","steps":[{"instruction":"List running services","command":"systemctl list-units --type=service --state=running | head -20","expectedOutput":"List of active services"},{"instruction":"Check a specific service","command":"systemctl status sshd 2>/dev/null || systemctl status ssh 2>/dev/null || echo 'SSH not found'","expectedOutput":"Service status with recent logs"},{"instruction":"Check if a service is enabled","command":"systemctl is-enabled sshd 2>/dev/null || systemctl is-enabled ssh 2>/dev/null || echo 'SSH not found'","expectedOutput":"enabled or disabled"}]},
  {"id":"lab-sd-2","chapterId":"systemd-services","title":"Checking Failed Services","description":"Find and diagnose failed services.","steps":[{"instruction":"List failed services","command":"systemctl --failed","expectedOutput":"List of failed units (may be empty)"},{"instruction":"Check the default target","command":"systemctl get-default","expectedOutput":"multi-user.target or graphical.target"},{"instruction":"List all targets","command":"systemctl list-units --type=target","expectedOutput":"Active targets"}]},
  {"id":"lab-sd-3","chapterId":"systemd-services","title":"Reading Service Logs","description":"Use journalctl to view service logs.","steps":[{"instruction":"View recent system logs","command":"journalctl --since '10 minutes ago' | tail -20","expectedOutput":"Recent log entries"},{"instruction":"View logs for a service","command":"journalctl -u sshd --since today 2>/dev/null || journalctl -u ssh --since today 2>/dev/null | tail -10","expectedOutput":"SSH service logs"},{"instruction":"View only errors","command":"journalctl -p err --since today | head -20","expectedOutput":"Error-level messages"}]},
  {"id":"lab-sd-4","chapterId":"systemd-services","title":"Examining Unit Files","description":"Read and understand systemd unit files.","steps":[{"instruction":"Find a unit file","command":"systemctl cat sshd 2>/dev/null || systemctl cat ssh 2>/dev/null || echo 'SSH not found'","expectedOutput":"Unit file contents with [Unit], [Service], [Install]"},{"instruction":"List unit file locations","command":"ls /etc/systemd/system/ | head -10","expectedOutput":"Custom unit files and symlinks"}]},
  {"id":"lab-mp-1","chapterId":"monitoring-performance","title":"Checking System Load","description":"Read and interpret load averages.","steps":[{"instruction":"View uptime and load","command":"uptime","expectedOutput":"load average: X.XX, X.XX, X.XX"},{"instruction":"Count CPU cores","command":"nproc","expectedOutput":"Number of cores"},{"instruction":"View detailed load info","command":"cat /proc/loadavg","expectedOutput":"Load averages and process counts"}]},
  {"id":"lab-mp-2","chapterId":"monitoring-performance","title":"Memory Analysis","description":"Check memory usage and understand the output.","steps":[{"instruction":"View memory usage","command":"free -h","expectedOutput":"total, used, free, buff/cache, available"},{"instruction":"Check what available means","command":"free -h | awk '/Mem:/ {print \"Available for programs: \" $7}'","expectedOutput":"Available memory amount"},{"instruction":"Check swap usage","command":"free -h | awk '/Swap:/ {print \"Swap used: \" $3}'","expectedOutput":"Swap usage"}]},
  {"id":"lab-mp-3","chapterId":"monitoring-performance","title":"Process Monitoring with top","description":"Use top to find resource-hungry processes.","steps":[{"instruction":"View top (exit with q)","command":"top -bn1 | head -20","expectedOutput":"System summary and top processes"},{"instruction":"Find top CPU consumers","command":"ps aux --sort=-%cpu | head -5","expectedOutput":"Processes sorted by CPU usage"},{"instruction":"Find top memory consumers","command":"ps aux --sort=-%mem | head -5","expectedOutput":"Processes sorted by memory usage"}]},
  {"id":"lab-mp-4","chapterId":"monitoring-performance","title":"I/O and Open Files","description":"Check disk I/O and open file descriptors.","steps":[{"instruction":"Check open files count","command":"lsof 2>/dev/null | wc -l || echo 'lsof not available'","expectedOutput":"Number of open files"},{"instruction":"Check what's using a common port","command":"sudo lsof -i :22 2>/dev/null || sudo ss -tlnp | grep :22","expectedOutput":"SSH process on port 22"},{"instruction":"View vmstat snapshot","command":"vmstat 1 3","expectedOutput":"3 snapshots of system stats"}]},
  {"id":"lab-lg-1","chapterId":"logging","title":"Exploring Log Files","description":"Navigate the /var/log directory.","steps":[{"instruction":"List log files","command":"ls /var/log/ | head -20","expectedOutput":"syslog, auth.log, kern.log, etc."},{"instruction":"View recent system logs","command":"tail -10 /var/log/syslog 2>/dev/null || tail -10 /var/log/messages 2>/dev/null || journalctl | tail -10","expectedOutput":"Recent log entries"},{"instruction":"Check auth logs","command":"sudo tail -10 /var/log/auth.log 2>/dev/null || sudo tail -10 /var/log/secure 2>/dev/null || sudo journalctl _COMM=sshd | tail -10","expectedOutput":"Authentication events"}]},
  {"id":"lab-lg-2","chapterId":"logging","title":"journalctl Filtering","description":"Use journalctl to find specific log entries.","steps":[{"instruction":"Logs since last boot","command":"journalctl -b | tail -20","expectedOutput":"Boot logs"},{"instruction":"Filter by priority","command":"journalctl -p warning --since today | head -20","expectedOutput":"Warnings and above"},{"instruction":"Check disk usage of journal","command":"journalctl --disk-usage","expectedOutput":"Archived and active journal size"}]},
  {"id":"lab-lg-3","chapterId":"logging","title":"Kernel Messages","description":"Read kernel messages with dmesg.","steps":[{"instruction":"View recent kernel messages","command":"dmesg | tail -20","expectedOutput":"Recent kernel messages"},{"instruction":"Check for errors","command":"dmesg | grep -i error | tail -10","expectedOutput":"Kernel errors (may be empty)"},{"instruction":"Check for USB devices","command":"dmesg | grep -i usb | tail -10","expectedOutput":"USB-related kernel messages"}]},
  {"id":"lab-lg-4","chapterId":"logging","title":"Checking for OOM Events","description":"Look for Out of Memory killer activity.","steps":[{"instruction":"Search dmesg for OOM","command":"dmesg | grep -i 'oom\\|out of memory' || echo 'No OOM events found'","expectedOutput":"OOM events or 'No OOM events found'"},{"instruction":"Check journal for OOM","command":"journalctl -k | grep -i oom | tail -5 || echo 'No OOM in journal'","expectedOutput":"OOM events from journal"},{"instruction":"View logrotate config","command":"cat /etc/logrotate.conf | head -20","expectedOutput":"Logrotate settings"}]},
  {"id":"lab-nw-1","chapterId":"networking","title":"Network Configuration","description":"View your network settings.","steps":[{"instruction":"View IP addresses","command":"ip addr | head -20","expectedOutput":"Interface names and IP addresses"},{"instruction":"View routing table","command":"ip route","expectedOutput":"default via GATEWAY dev INTERFACE"},{"instruction":"Quick IP check","command":"hostname -I","expectedOutput":"Your IP address(es)"}]},
  {"id":"lab-nw-2","chapterId":"networking","title":"Checking Ports and Connections","description":"Use ss to view network connections.","steps":[{"instruction":"List listening TCP ports","command":"ss -tlnp","expectedOutput":"TCP listening sockets with ports"},{"instruction":"List all TCP connections","command":"ss -tn | head -20","expectedOutput":"Active TCP connections"},{"instruction":"Summary of connections","command":"ss -s","expectedOutput":"TCP, UDP connection summary"}]},
  {"id":"lab-nw-3","chapterId":"networking","title":"DNS Lookups","description":"Resolve domain names to IP addresses.","steps":[{"instruction":"Look up a domain","command":"dig google.com +short","expectedOutput":"IP address(es)"},{"instruction":"View DNS servers","command":"cat /etc/resolv.conf","expectedOutput":"nameserver entries"},{"instruction":"Check /etc/hosts","command":"cat /etc/hosts","expectedOutput":"localhost and any custom entries"}]},
  {"id":"lab-nw-4","chapterId":"networking","title":"Connectivity Testing","description":"Test network connectivity with various tools.","steps":[{"instruction":"Ping a host","command":"ping -c 3 google.com","expectedOutput":"3 packets transmitted, 3 received"},{"instruction":"Trace the route","command":"traceroute -m 10 google.com 2>/dev/null || tracepath google.com 2>/dev/null | head -10","expectedOutput":"Hops to destination"},{"instruction":"Fetch HTTP headers","command":"curl -I https://google.com 2>/dev/null | head -5","expectedOutput":"HTTP/2 301 or 200 status"},{"instruction":"Test if a port is open","command":"nc -zv google.com 443 2>&1 || echo 'nc not available'","expectedOutput":"Connection succeeded or refused"}]},
  {"id":"lab-nw-5","chapterId":"networking","title":"SSH Key Setup","description":"Generate and understand SSH keys.","steps":[{"instruction":"Check for existing keys","command":"ls -la ~/.ssh/ 2>/dev/null || echo 'No .ssh directory'","expectedOutput":"Existing keys or no directory"},{"instruction":"View SSH config if it exists","command":"cat ~/.ssh/config 2>/dev/null || echo 'No SSH config file'","expectedOutput":"SSH config or message"},{"instruction":"Check SSH key permissions","command":"stat -c '%a %n' ~/.ssh/* 2>/dev/null || echo 'No SSH files'","expectedOutput":"Permission numbers for SSH files"}]},
  {"id":"lab-bs-1","chapterId":"bash-scripting","title":"Your First Script","description":"Create and run a basic bash script.","steps":[{"instruction":"Create a script file","command":"echo '#!/bin/bash\nset -euo pipefail\necho \"Hello from my first script!\"\necho \"Today is $(date)\"\necho \"You are $(whoami)\"' > ~/myscript.sh","expectedOutput":""},{"instruction":"Make it executable","command":"chmod +x ~/myscript.sh","expectedOutput":""},{"instruction":"Run it","command":"~/myscript.sh","expectedOutput":"Hello from my first script! + date + username"},{"instruction":"Clean up","command":"rm ~/myscript.sh","expectedOutput":""}]},
  {"id":"lab-bs-2","chapterId":"bash-scripting","title":"Variables and Arguments","description":"Work with variables and script arguments.","steps":[{"instruction":"Create a greeting script","command":"echo '#!/bin/bash\nset -euo pipefail\nname=\"${1:-World}\"\necho \"Hello, $name!\"\necho \"Script: $0\"\necho \"Args: $#\"' > ~/greet.sh && chmod +x ~/greet.sh","expectedOutput":""},{"instruction":"Run without arguments","command":"~/greet.sh","expectedOutput":"Hello, World!"},{"instruction":"Run with an argument","command":"~/greet.sh Linux","expectedOutput":"Hello, Linux!"},{"instruction":"Clean up","command":"rm ~/greet.sh","expectedOutput":""}]},
  {"id":"lab-bs-3","chapterId":"bash-scripting","title":"Conditionals and Loops","description":"Use if statements and for loops.","steps":[{"instruction":"Create a file checker script","command":"echo '#!/bin/bash\nset -euo pipefail\nfor f in /etc/passwd /etc/shadow /nonexistent; do\n  if [ -f \"$f\" ]; then\n    echo \"EXISTS: $f\"\n  else\n    echo \"MISSING: $f\"\n  fi\ndone' > ~/checker.sh && chmod +x ~/checker.sh","expectedOutput":""},{"instruction":"Run it","command":"~/checker.sh","expectedOutput":"EXISTS: /etc/passwd, EXISTS: /etc/shadow, MISSING: /nonexistent"},{"instruction":"Clean up","command":"rm ~/checker.sh","expectedOutput":""}]},
  {"id":"lab-bs-4","chapterId":"bash-scripting","title":"Functions and Exit Codes","description":"Write functions and check exit codes.","steps":[{"instruction":"Create a function script","command":"echo '#!/bin/bash\nset -euo pipefail\ncheck_file() {\n  local file=\"$1\"\n  if [ -f \"$file\" ]; then\n    echo \"Found: $file ($(wc -l < \"$file\") lines)\"\n    return 0\n  else\n    echo \"Not found: $file\"\n    return 1\n  fi\n}\ncheck_file /etc/passwd\ncheck_file /etc/hostname || true' > ~/funcs.sh && chmod +x ~/funcs.sh","expectedOutput":""},{"instruction":"Run it","command":"~/funcs.sh","expectedOutput":"Found: /etc/passwd (N lines) and hostname result"},{"instruction":"Clean up","command":"rm ~/funcs.sh","expectedOutput":""}]},
  {"id":"lab-bp-1","chapterId":"boot-process","title":"Kernel Information","description":"Examine your running kernel.","steps":[{"instruction":"Check kernel version","command":"uname -r","expectedOutput":"Kernel version string"},{"instruction":"View full kernel info","command":"uname -a","expectedOutput":"Kernel name, version, architecture"},{"instruction":"List installed kernels","command":"ls /boot/vmlinuz* 2>/dev/null || ls /boot/kernel* 2>/dev/null || echo 'Kernel files not in expected location'","expectedOutput":"Kernel file(s)"}]},
  {"id":"lab-bp-2","chapterId":"boot-process","title":"Boot Time Analysis","description":"Analyze how long your system took to boot.","steps":[{"instruction":"Check boot time","command":"systemd-analyze 2>/dev/null || echo 'systemd-analyze not available'","expectedOutput":"Startup finished in X.XXXs"},{"instruction":"Slowest services","command":"systemd-analyze blame 2>/dev/null | head -10 || echo 'Not available'","expectedOutput":"Services sorted by startup time"},{"instruction":"View boot logs","command":"journalctl -b | head -20","expectedOutput":"First messages from current boot"}]},
  {"id":"lab-bp-3","chapterId":"boot-process","title":"Kernel Modules","description":"View and understand kernel modules.","steps":[{"instruction":"List loaded modules","command":"lsmod | head -20","expectedOutput":"Module names, sizes, and dependencies"},{"instruction":"Count loaded modules","command":"lsmod | wc -l","expectedOutput":"Number of loaded modules"},{"instruction":"Get info about a module","command":"modinfo ext4 2>/dev/null || modinfo xfs 2>/dev/null || echo 'Module not found'","expectedOutput":"Module description, author, license"}]},
  {"id":"lab-bp-4","chapterId":"boot-process","title":"GRUB Configuration","description":"Examine the bootloader configuration.","steps":[{"instruction":"View GRUB defaults","command":"cat /etc/default/grub 2>/dev/null || echo 'GRUB config not found (may use different bootloader)'","expectedOutput":"GRUB_TIMEOUT, GRUB_CMDLINE_LINUX settings"},{"instruction":"Check boot parameters","command":"cat /proc/cmdline","expectedOutput":"Kernel command line parameters"}]},
  {"id":"lab-qa-1","chapterId":"interview-qa","title":"Hard Links vs Symlinks Hands-On","description":"Demonstrate the difference with real commands.","steps":[{"instruction":"Create a file","command":"echo 'original content' > ~/qa_test.txt","expectedOutput":""},{"instruction":"Create both link types","command":"ln ~/qa_test.txt ~/qa_hard.txt && ln -s ~/qa_test.txt ~/qa_sym.txt","expectedOutput":""},{"instruction":"Compare inodes","command":"ls -li ~/qa_test.txt ~/qa_hard.txt ~/qa_sym.txt","expectedOutput":"Hard link has same inode, symlink has different inode"},{"instruction":"Delete original and test","command":"rm ~/qa_test.txt && echo '--- Hard link: ---' && cat ~/qa_hard.txt && echo '--- Symlink: ---' && cat ~/qa_sym.txt 2>&1 || true","expectedOutput":"Hard link works, symlink fails"},{"instruction":"Clean up","command":"rm -f ~/qa_hard.txt ~/qa_sym.txt","expectedOutput":""}]},
  {"id":"lab-qa-2","chapterId":"interview-qa","title":"Process States Investigation","description":"Find processes in different states.","steps":[{"instruction":"Find running processes","command":"ps aux | awk '$8 ~ /R/ {print $2, $8, $11}' | head -5","expectedOutput":"PIDs in R state"},{"instruction":"Find sleeping processes","command":"ps aux | awk '$8 ~ /S/ {print $2, $8, $11}' | head -5","expectedOutput":"PIDs in S state"},{"instruction":"Check for zombies","command":"ps aux | awk '$8 ~ /Z/' || echo 'No zombie processes'","expectedOutput":"Zombie processes or none found"}]},
  {"id":"lab-qa-3","chapterId":"interview-qa","title":"PATH Troubleshooting","description":"Understand and fix PATH issues.","steps":[{"instruction":"View your PATH","command":"echo $PATH | tr ':' '\\n'","expectedOutput":"Each directory in PATH on its own line"},{"instruction":"Find where a command lives","command":"which ls","expectedOutput":"/bin/ls or /usr/bin/ls"},{"instruction":"Simulate a PATH issue","command":"PATH=/tmp which ls 2>&1 || echo 'ls not found — PATH is wrong!'","expectedOutput":"ls not found message"},{"instruction":"Verify PATH is restored","command":"which ls","expectedOutput":"/bin/ls or /usr/bin/ls (PATH is fine in this shell)"}]},
  {"id":"lab-qa-4","chapterId":"interview-qa","title":"System Diagnosis Practice","description":"Practice the diagnostic workflow for a slow system.","steps":[{"instruction":"Check load average","command":"uptime","expectedOutput":"Load averages"},{"instruction":"Check memory","command":"free -h","expectedOutput":"Memory usage summary"},{"instruction":"Check top CPU processes","command":"ps aux --sort=-%cpu | head -5","expectedOutput":"Top CPU consumers"},{"instruction":"Check disk space","command":"df -h | grep -v tmpfs","expectedOutput":"Disk usage per filesystem"},{"instruction":"Check for errors in logs","command":"journalctl -p err --since '1 hour ago' 2>/dev/null | tail -10 || dmesg | grep -i error | tail -10","expectedOutput":"Recent errors if any"}]}
]
